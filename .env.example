# TCG News Brief — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub (it's in .gitignore).

# ── AI (required) ─────────────────────────────────────────────────────────────
# Free Gemini API key: https://aistudio.google.com/app/apikey
# ⚠️  Key must start with "AIzaSy..." — if yours starts with "AQ." it's wrong
GEMINI_API_KEY=AIzaSy_your_key_here

# ── Email — Resend (recommended, no 2FA needed) ───────────────────────────────
# Free at https://resend.com — 3,000 emails/month
RESEND_API_KEY=re_your_key_here

# ── Recipients (comma-separated) ─────────────────────────────────────────────
EMAIL_RECIPIENTS=tcgnews@thecommongood.net
